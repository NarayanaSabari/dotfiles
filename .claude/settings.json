{
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl logs *)",
      "Bash(docker compose config *)",
      "Bash(treehouse status)",
      "Bash(no-mistakes status *)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/sabari/.claude/hooks/git-identity-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "/Users/sabari/.claude/hooks/git-guardrails.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/sabari/.claude/hooks/notify.sh attention",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/sabari/.claude/hooks/notify.sh done",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/sabari/.claude/statusline.sh"
  },
  "enabledPlugins": {},
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "*.githubusercontent.com",
        "registry.npmjs.org"
      ]
    },
    "excludedCommands": [
      "codex"
    ]
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "custom:brewer-dark",
  "preferredNotifChannel": "terminal_bell",
  "terminalProgressBarEnabled": true,
  "teammateMode": "tmux"
}
